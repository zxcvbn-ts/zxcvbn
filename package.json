{
  "workspaces": [
    "packages/languages/*",
    "packages/libraries/*"
  ],
  "private": true,
  "name": "zxcvbn-ts",
  "version": "4.4.2",
  "description": "Realistic password strength estimation written in typescript",
  "author": "zxcvbn-ts",
  "license": "MIT",
  "homepage": "https://github.com/zxcvbn-ts/zxcvbn",
  "repository": {
    "type": "git",
    "url": "git@github.com:zxcvbn-ts/zxcvbn.git"
  },
  "files": [],
  "prettier": "./prettier.mjs",
  "scripts": {
    "build": "lerna exec --parallel -- rollup -c ../../../scripts/rollup.config.mjs",
    "lint": "eslint --ext .js,.mjs,.ts --fix --cache .",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "changed": "lerna changed",
    "lerna-publish": "yarn build && lerna publish --conventional-commits -y",
    "lerna-publish:beta": "yarn build && lerna publish premajor --preid beta --dist-tag beta -y",
    "generate:languageData": "yarn start-ts-file ./data-scripts/generate.ts",
    "generate:deduplicate": "yarn start-ts-file ./data-scripts/deduplicate.ts",
    "wikipediaExtractor": "yarn start-ts-file ./data-scripts/wikiExtractor/index.ts ./data-scripts/extracts",
    "start-ts-file": "node -r esbuild-register --unhandled-rejections=strict",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@eslint/compat": "2.0.5",
    "@eslint/js": "10.0.1",
    "@rollup/plugin-alias": "6.0.0",
    "@rollup/plugin-babel": "7.0.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@swc/core": "1.15.30",
    "@swc/jest": "0.2.39",
    "@types/byline": "4.2.36",
    "@types/jest": "30.0.0",
    "@types/sprintf-js": "1.1.4",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vuepress/bundler-vite": "2.0.0-rc.28",
    "@vuepress/plugin-register-components": "2.0.0-rc.128",
    "@vuepress/theme-default": "2.0.0-rc.128",
    "@zxcvbn-ts/dictionary-compression": "3.0.1",
    "axios": "1.15.2",
    "byline": "5.0.0",
    "chinese-to-pinyin": "1.3.1",
    "cross-fetch": "4.1.0",
    "esbuild": "0.28.0",
    "esbuild-register": "3.6.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-webpack": "0.13.11",
    "eslint-plugin-compat": "7.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sort-class-members": "1.22.1",
    "esm": "3.2.25",
    "iconv-lite": "0.7.2",
    "jest": "30.3.0",
    "jszip": "3.10.1",
    "kuroshiro": "1.2.0",
    "kuroshiro-analyzer-kuromoji": "1.1.0",
    "lerna": "9.0.7",
    "natural": "8.1.1",
    "nodejieba": "3.5.8",
    "prettier": "3.8.3",
    "rollup": "4.60.2",
    "rollup-plugin-copy": "3.5.0",
    "rollup-plugin-delete": "3.0.2",
    "sass-embedded": "1.99.0",
    "sprintf-js": "1.1.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vue-multiselect": "3.5.0",
    "vuepress": "2.0.0-rc.28",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yarn-audit-fix": "10.1.1",
    "zxcvbn": "4.4.2"
  },
  "keywords": [
    "password",
    "passphrase",
    "security",
    "authentication",
    "strength",
    "meter",
    "quality",
    "estimation",
    "pattern",
    "cracking",
    "scoring",
    "entropy",
    "bruteforce"
  ],
  "resolutions": {},
  "overrides": {},
  "dependencies": {}
}
